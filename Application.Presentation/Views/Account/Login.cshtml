@model LoginViewModel
@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/_AuthLayout.cshtml";
}

<!-- main -->
<div class="main-w3layouts wrapper">
	<h1>Creative Login Form</h1>
	<div class="main-agileinfo">
		<div class="agileits-top">
			<form asp-action="Login" asp-controller="Account" method="post">
				<div asp-validation-summary="ModelOnly" class="alert-danger"></div>
				<div class="pb-3">
					<input asp-for="Email" placeholder="Email">
					<span class="alert-danger" asp-validation-for="Email"></span>
				</div>
				<div class="pb-3">
					<input asp-for="Password" placeholder="Password">
					<span class="alert-danger" asp-validation-for="Password"></span>
				</div>
				<div class="wthree-text">
					<label class="anim">
						<input asp-for="RememberMe">
						<span>Remember Me</span>
					</label>
					<div class="clear"> </div>
				</div>
				<input type="submit" value="SIGNIN">
			</form>
			<p>Don't have an Account? <a asp-action="Register" asp-controller="Account"> Register Now!</a></p>
			<p>Froget Password? <a asp-action="ForgetPassword" asp-controller="Account"> Reset Password Now!</a></p>
		</div>
	</div>
</div>
<!-- //main -->

